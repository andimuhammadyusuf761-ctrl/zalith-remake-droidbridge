<?xml version="1.0" encoding="utf-8"?>
<!--
    Large ambient teal radial glow placed behind the right play panel.
    Gives a soft "deep ocean" light source effect on dark slate.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="180dp"
        android:startColor="#1200E5FF"
        android:centerColor="#0A00BFA5"
        android:endColor="#00000000" />
</shape>
