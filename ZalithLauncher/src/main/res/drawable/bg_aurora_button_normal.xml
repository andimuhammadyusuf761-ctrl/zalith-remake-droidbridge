<?xml version="1.0" encoding="utf-8"?>
<!--
    Aurora Button Normal — Teal Ocean variant.
    3D raised look: shadow + teal gradient + glass top sheen.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom shadow -->
    <item android:top="3dp" android:left="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_10sdp" />
            <solid android:color="#40003D33" />
        </shape>
    </item>
    <!-- Teal gradient body -->
    <item android:bottom="3dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_10sdp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/teal_deep"
                android:endColor="@color/teal_primary" />
            <stroke
                android:width="0.5dp"
                android:color="@color/glass_border" />
        </shape>
    </item>
    <!-- Top glass sheen -->
    <item android:bottom="3dp" android:right="2dp">
        <inset android:insetBottom="55%">
            <shape android:shape="rectangle">
                <corners
                    android:topLeftRadius="@dimen/_10sdp"
                    android:topRightRadius="@dimen/_10sdp"
                    android:bottomLeftRadius="0dp"
                    android:bottomRightRadius="0dp" />
                <gradient
                    android:startColor="#20FFFFFF"
                    android:endColor="#00FFFFFF"
                    android:angle="270" />
            </shape>
        </inset>
    </item>
</layer-list>
