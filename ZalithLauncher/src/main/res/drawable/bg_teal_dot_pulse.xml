<?xml version="1.0" encoding="utf-8"?>
<!--
    Small teal status dot shown in the top bar.
    Solid bright teal circle with soft glow ring.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#3300E5FF" />
        </shape>
    </item>
    <!-- Solid teal core -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#00BFA5" />
        </shape>
    </item>
</layer-list>
