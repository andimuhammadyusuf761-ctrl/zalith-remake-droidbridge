<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash screen background orb — large radial teal glow behind the app icon.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer diffuse glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="70dp"
                android:startColor="#2200BFA5"
                android:centerColor="#1000897B"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Inner teal ring -->
    <item android:top="16dp" android:left="16dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#4400E5FF" />
            <solid android:color="#08004D40" />
        </shape>
    </item>
</layer-list>
