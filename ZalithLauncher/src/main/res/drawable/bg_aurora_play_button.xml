<?xml version="1.0" encoding="utf-8"?>
<!--
    Aurora Play Button — Teal Ocean variant (replaces old indigo→violet→cyan).
    Layers: shadow → teal gradient body → glass shine → bottom depth.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#5500E5FF">
    <item>
        <layer-list>
            <!-- Deep shadow for 3D raise -->
            <item android:top="3dp" android:left="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/_16sdp" />
                    <solid android:color="#55000000" />
                </shape>
            </item>
            <!-- Teal gradient body -->
            <item android:bottom="3dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/_16sdp" />
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="@color/aurora_indigo_deep"
                        android:centerColor="@color/aurora_indigo"
                        android:endColor="@color/aurora_cyan" />
                    <stroke
                        android:width="0.6dp"
                        android:color="@color/aurora_violet_bright" />
                </shape>
            </item>
            <!-- Top glass shine -->
            <item android:bottom="3dp" android:right="2dp">
                <inset android:insetBottom="55%">
                    <shape android:shape="rectangle">
                        <corners
                            android:topLeftRadius="@dimen/_16sdp"
                            android:topRightRadius="@dimen/_16sdp"
                            android:bottomLeftRadius="0dp"
                            android:bottomRightRadius="0dp" />
                        <gradient
                            android:startColor="#2EFFFFFF"
                            android:endColor="#00FFFFFF"
                            android:angle="270" />
                    </shape>
                </inset>
            </item>
            <!-- Bottom depth -->
            <item android:bottom="3dp" android:right="2dp">
                <inset android:insetTop="65%">
                    <shape android:shape="rectangle">
                        <corners
                            android:topLeftRadius="0dp"
                            android:topRightRadius="0dp"
                            android:bottomLeftRadius="@dimen/_16sdp"
                            android:bottomRightRadius="@dimen/_16sdp" />
                        <gradient
                            android:startColor="#00000000"
                            android:endColor="#33000000"
                            android:angle="270" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
</ripple>
