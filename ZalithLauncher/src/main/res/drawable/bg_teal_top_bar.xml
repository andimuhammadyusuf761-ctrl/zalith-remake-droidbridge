<?xml version="1.0" encoding="utf-8"?>
<!--
    Teal Ocean Top Bar.
    Dark slate glass with horizontal teal gradient, top highlight sheen,
    and a bottom teal glow border for floating depth.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark glass body -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#CC004D40"
                android:centerColor="#CC00695C"
                android:endColor="#CC004D40" />
        </shape>
    </item>
    <!-- Teal shimmer overlay (diagonal) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#2200E5FF"
                android:centerColor="#1100BFA5"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Top glass sheen -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#1EFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
    <!-- Bottom teal glow border -->
    <item android:top="54dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:endColor="#5500BFA5" />
        </shape>
    </item>
</layer-list>
