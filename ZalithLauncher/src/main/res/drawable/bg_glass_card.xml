<?xml version="1.0" encoding="utf-8"?>
<!--
    Glass Card — Teal Ocean variant.
    Dark slate glass with teal border stroke and top highlight.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <solid android:color="#1A00BFA5" />
        </shape>
    </item>
    <!-- Glass body -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <solid android:color="@color/glass_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_border" />
        </shape>
    </item>
    <!-- Top glass sheen -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <gradient
                android:startColor="#12FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
