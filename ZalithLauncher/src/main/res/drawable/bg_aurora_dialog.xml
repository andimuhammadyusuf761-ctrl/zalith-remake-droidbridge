<?xml version="1.0" encoding="utf-8"?>
<!--
    Aurora Dialog Background — Teal Ocean glassmorphic.
    Dark slate glass body with teal border glow and top sheen.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer teal glow shadow -->
    <item android:top="4dp" android:left="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_16sdp" />
            <solid android:color="#1A00BFA5" />
        </shape>
    </item>
    <!-- Dark glass body -->
    <item android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_16sdp" />
            <solid android:color="@color/glass_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_border_strong" />
        </shape>
    </item>
    <!-- Top glass sheen -->
    <item android:bottom="4dp" android:right="4dp">
        <inset android:insetBottom="70%">
            <shape android:shape="rectangle">
                <corners
                    android:topLeftRadius="@dimen/_16sdp"
                    android:topRightRadius="@dimen/_16sdp"
                    android:bottomLeftRadius="0dp"
                    android:bottomRightRadius="0dp" />
                <gradient
                    android:startColor="#14FFFFFF"
                    android:endColor="#00FFFFFF"
                    android:angle="270" />
            </shape>
        </inset>
    </item>
</layer-list>
