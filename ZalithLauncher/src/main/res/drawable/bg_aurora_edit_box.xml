<?xml version="1.0" encoding="utf-8"?>
<!--
    Aurora Edit Box (v3 GUI):
    Recessed surface with focus ring driven by aurora_violet.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/_12sdp" />
                    <solid android:color="@color/edit_box_fill_selected" />
                    <stroke
                        android:width="1.4dp"
                        android:color="@color/aurora_violet" />
                </shape>
            </item>
            <!-- Recessed inner top shadow -->
            <item>
                <inset android:insetBottom="80%">
                    <shape android:shape="rectangle">
                        <corners
                            android:topLeftRadius="@dimen/_12sdp"
                            android:topRightRadius="@dimen/_12sdp"
                            android:bottomLeftRadius="0dp"
                            android:bottomRightRadius="0dp" />
                        <gradient
                            android:startColor="#22000000"
                            android:endColor="#00000000"
                            android:angle="270" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/_12sdp" />
                    <solid android:color="@color/edit_box_fill" />
                    <stroke
                        android:width="0.6dp"
                        android:color="@color/aurora_outline" />
                </shape>
            </item>
            <item>
                <inset android:insetBottom="80%">
                    <shape android:shape="rectangle">
                        <corners
                            android:topLeftRadius="@dimen/_12sdp"
                            android:topRightRadius="@dimen/_12sdp"
                            android:bottomLeftRadius="0dp"
                            android:bottomRightRadius="0dp" />
                        <gradient
                            android:startColor="#18000000"
                            android:endColor="#00000000"
                            android:angle="270" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
</selector>
