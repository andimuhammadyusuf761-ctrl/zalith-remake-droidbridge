<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 3D recessed edit box -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_10sdp" />
            <solid android:color="@color/edit_box_fill" />
            <stroke
                android:width="0.5dp"
                android:color="#20000000" />
        </shape>
    </item>
    <!-- Inner top shadow for depth -->
    <item>
        <inset android:insetBottom="80%">
            <shape android:shape="rectangle">
                <corners
                    android:topLeftRadius="@dimen/_10sdp"
                    android:topRightRadius="@dimen/_10sdp"
                    android:bottomLeftRadius="0dp"
                    android:bottomRightRadius="0dp" />
                <gradient
                    android:startColor="#10000000"
                    android:endColor="#00000000"
                    android:angle="270" />
            </shape>
        </inset>
    </item>
</layer-list>
