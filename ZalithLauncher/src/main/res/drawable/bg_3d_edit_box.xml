<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <!-- Inset shadow for 3D recessed look -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/_10sdp" />
                    <solid android:color="@color/edit_box_fill_selected" />
                    <stroke
                        android:width="1.5dp"
                        android:color="@color/accent_primary" />
                </shape>
            </item>
            <!-- Inner top shadow to make it look recessed -->
            <item>
                <inset android:insetBottom="80%">
                    <shape android:shape="rectangle">
                        <corners
                            android:topLeftRadius="@dimen/_10sdp"
                            android:topRightRadius="@dimen/_10sdp"
                            android:bottomLeftRadius="0dp"
                            android:bottomRightRadius="0dp" />
                        <gradient
                            android:startColor="#15000000"
                            android:endColor="#00000000"
                            android:angle="270" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/_10sdp" />
                    <solid android:color="@color/edit_box_fill" />
                    <stroke
                        android:width="0.5dp"
                        android:color="#20000000" />
                </shape>
            </item>
            <item>
                <inset android:insetBottom="80%">
                    <shape android:shape="rectangle">
                        <corners
                            android:topLeftRadius="@dimen/_10sdp"
                            android:topRightRadius="@dimen/_10sdp"
                            android:bottomLeftRadius="0dp"
                            android:bottomRightRadius="0dp" />
                        <gradient
                            android:startColor="#10000000"
                            android:endColor="#00000000"
                            android:angle="270" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
</selector>
