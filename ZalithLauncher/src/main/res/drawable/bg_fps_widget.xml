<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow effect -->
    <item android:top="1dp" android:left="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_8sdp" />
            <solid android:color="#2014B8A6" />
        </shape>
    </item>
    <!-- Glass card body -->
    <item android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_8sdp" />
            <solid android:color="#CC1E293B" />
            <stroke
                android:width="1dp"
                android:color="#4014B8A6" />
        </shape>
    </item>
    <!-- Top shine for glass effect -->
    <item android:bottom="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_8sdp" />
            <gradient
                android:startColor="#15FFFFFF"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
