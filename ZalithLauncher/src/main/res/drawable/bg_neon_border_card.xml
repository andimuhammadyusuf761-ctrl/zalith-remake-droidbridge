<?xml version="1.0" encoding="utf-8"?>
<!--
    Neon Border Card — Teal Ocean (replaces old 14B8A6 teal).
    Teal glow outer + dark glass body + teal stroke + inner sheen.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Teal neon glow outer -->
    <item android:top="2dp" android:left="2dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <solid android:color="#2200BFA5" />
        </shape>
    </item>
    <!-- Card body -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <solid android:color="@color/glass_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_border_strong" />
        </shape>
    </item>
    <!-- Inner top highlight -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <gradient
                android:startColor="#10FFFFFF"
                android:centerColor="#05FFFFFF"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
