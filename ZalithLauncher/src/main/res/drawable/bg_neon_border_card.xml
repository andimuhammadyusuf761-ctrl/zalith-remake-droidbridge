<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Neon glow outer -->
    <item android:top="2dp" android:left="2dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <solid android:color="#1814B8A6" />
        </shape>
    </item>
    <!-- Card body -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <solid android:color="@color/background_item" />
            <stroke
                android:width="1dp"
                android:color="#3014B8A6" />
        </shape>
    </item>
    <!-- Inner top highlight -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_14sdp" />
            <gradient
                android:startColor="#12FFFFFF"
                android:centerColor="#06FFFFFF"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
