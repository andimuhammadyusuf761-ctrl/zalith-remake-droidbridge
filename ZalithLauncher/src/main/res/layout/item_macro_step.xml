<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/_4sdp"
    android:layout_marginVertical="@dimen/_3sdp"
    android:background="@drawable/bg_aurora_menu_item"
    android:padding="@dimen/_8sdp">

    <TextView
        android:id="@+id/step_index"
        android:layout_width="@dimen/_24sdp"
        android:layout_height="@dimen/_24sdp"
        android:background="@drawable/bg_aurora_chip"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="1" />

    <TextView
        android:id="@+id/step_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_8sdp"
        android:textColor="@color/black_or_white"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/step_up"
        app:layout_constraintStart_toEndOf="@+id/step_index"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Right Click" />

    <TextView
        android:id="@+id/step_sub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_8sdp"
        android:layout_marginTop="@dimen/_2sdp"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@+id/step_up"
        app:layout_constraintStart_toEndOf="@+id/step_index"
        app:layout_constraintTop_toBottomOf="@+id/step_label"
        tools:text="delay 30ms" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/step_up"
        android:layout_width="@dimen/_28sdp"
        android:layout_height="@dimen/_28sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/macro_move_up"
        android:padding="@dimen/_4sdp"
        android:src="@drawable/ic_aurora_arrow_up"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/step_down"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/step_down"
        android:layout_width="@dimen/_28sdp"
        android:layout_height="@dimen/_28sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/macro_move_down"
        android:padding="@dimen/_4sdp"
        android:src="@drawable/ic_aurora_arrow_down"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/step_edit"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/step_edit"
        android:layout_width="@dimen/_28sdp"
        android:layout_height="@dimen/_28sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/macro_edit"
        android:padding="@dimen/_4sdp"
        android:src="@drawable/ic_edit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/step_delete"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/step_delete"
        android:layout_width="@dimen/_28sdp"
        android:layout_height="@dimen/_28sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/generic_delete"
        android:padding="@dimen/_4sdp"
        android:src="@drawable/ic_menu_delete_forever"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
