<?xml version="1.0" encoding="utf-8"?>
<!--
    DroidBridge-style Launcher Home Fragment.
    Material3 card-based UI: instance list on left, play panel on right.
    This mirrors DroidBridge Launcher's instance-centric home screen.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:ignore="ContentDescription">

    <!-- Top content scrim (gradient from surface to transparent downward) -->
    <View
        android:id="@+id/mainTopScrim"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_main_top_content_scrim"
        android:clickable="false"
        android:focusable="false" />

    <!-- Floating top bar (DroidBridge-style pill card) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

            <!-- App / Launcher name -->
            <TextView
                android:id="@+id/db_app_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold" />

            <!-- FPS Boost chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/db_fps_boost_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FPS BOOST"
                app:chipBackgroundColor="@color/aurora_indigo"
                app:chipMinHeight="28dp"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                app:closeIconVisible="false" />

            <!-- Settings button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/db_settings_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text=""
                app:icon="@drawable/ic_menu_settings"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main content: instance list (left) + play panel (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingTop="72dp"
        android:paddingBottom="0dp">

        <!-- LEFT: Instance list -->
        <LinearLayout
            android:id="@+id/db_instance_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="6dp"
            android:paddingBottom="12dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Instances"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    android:textStyle="bold" />

                <!-- Mods button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/db_mods_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="Mods"
                    app:icon="@drawable/ic_download" />

                <!-- New instance button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/db_new_instance_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New"
                    app:icon="@drawable/ic_add" />
            </LinearLayout>

            <!-- Instance list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/db_instance_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <!-- RIGHT: Play panel -->
        <LinearLayout
            android:id="@+id/db_play_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="16dp">

            <!-- Account card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/db_account_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/db_player_head"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:contentDescription="@string/main_player_head_signed_out"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_account" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/db_account_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/status_signed_out"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/db_account_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to sign in"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/db_account_button"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account"
                        app:icon="@drawable/ic_aurora_arrow_down" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Selected version card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/db_version_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/db_version_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_instance_vanilla_24"
                        android:contentDescription="Version" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/db_version_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No version selected"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/db_version_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap an instance to select"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/db_version_picker_button"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Pick version"
                        android:src="@drawable/ic_arrow_drop_down_24"
                        android:scaleType="fitCenter" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PLAY button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/db_play_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="PLAY"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textSize="16sp"
                app:backgroundTint="@color/aurora_indigo"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Bottom scrim -->
    <View
        android:id="@+id/mainBottomScrim"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_main_bottom_content_scrim"
        android:clickable="false"
        android:focusable="false" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
