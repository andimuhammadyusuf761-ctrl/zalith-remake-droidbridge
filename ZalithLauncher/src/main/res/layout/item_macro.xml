<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/_4sdp"
    android:layout_marginVertical="@dimen/_3sdp"
    android:background="@drawable/bg_aurora_menu_item"
    android:padding="@dimen/_10sdp">

    <TextView
        android:id="@+id/macro_item_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/_6sdp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/black_or_white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/macro_item_run"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Auto-bridge" />

    <TextView
        android:id="@+id/macro_item_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_2sdp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@+id/macro_item_run"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/macro_item_name"
        tools:text="6 steps · 240ms total · loop ∞" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/macro_item_run"
        android:layout_width="@dimen/_32sdp"
        android:layout_height="@dimen/_32sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/macro_run_test"
        android:padding="@dimen/_4sdp"
        android:src="@drawable/ic_aurora_play"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/macro_item_edit"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/macro_item_edit"
        android:layout_width="@dimen/_32sdp"
        android:layout_height="@dimen/_32sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/macro_edit"
        android:padding="@dimen/_4sdp"
        android:src="@drawable/ic_edit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/macro_item_delete"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/macro_item_delete"
        android:layout_width="@dimen/_32sdp"
        android:layout_height="@dimen/_32sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/generic_delete"
        android:padding="@dimen/_4sdp"
        android:src="@drawable/ic_menu_delete_forever"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
