<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@style/Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:windowBackground">@color/background_app</item>
        <item name="android:colorAccent">@color/accent_primary</item>
    </style>

    <style name="CustomDialogStyle" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>

    <style name="RoundedCornersImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">6%</item>
    </style>

    <style name="RoundImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- DroidBridge theme — Teal Ocean + Dark Slate (Material3 dark) -->
    <style name="DroidBridgeSettingsTheme" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/slate_900</item>
        <item name="android:navigationBarColor">@color/slate_900</item>
        <item name="android:windowBackground">@color/slate_900</item>
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/teal_deep</item>
        <item name="colorSecondary">@color/cyan_primary</item>
        <item name="colorTertiary">@color/cyan_bright</item>
        <item name="colorSurface">@color/slate_800</item>
        <item name="colorOnSurface">@color/primary_text</item>
        <item name="android:textColorPrimary">@color/primary_text</item>
    </style>

    <!-- DroidBridge glass card style — teal ocean -->
    <style name="DroidBridgeCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Base ShapeAppearanceOverlay style -->
    <style name="ShapeAppearanceOverlay" parent="">
    </style>

    <!-- Project icon shapes — from DroidBridge -->
    <style name="ShapeAppearanceOverlay.JavaLauncher">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.JavaLauncher.ProjectIcon">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.JavaLauncher.ResourceIcon">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>
</resources>
